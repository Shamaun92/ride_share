# Copy this file to `.env` and adjust for your environment.
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# JWT signing secret — must be at least 32 characters.
SECRET_KEY=change-me-to-a-random-32char-plus-string

# Postgres — use 'db' inside docker-compose, 'localhost' when running outside.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rideshare

# Redis — use 'redis' inside docker-compose, 'localhost' when running outside.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Admin bootstrap secret (used by /api/v1/admin/bootstrap).
ADMIN_BOOTSTRAP_SECRET=admin-secret-local

# Allowed CORS origins for the frontend.
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
